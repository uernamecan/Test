{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "electron"
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "dist-electron",
    "rootDir": "."
  },
  "include": [
    "electron/**/*.ts",
    "scripts/**/*.ts",
    "src/types/**/*.ts"
  ]
}
