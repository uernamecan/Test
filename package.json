{
  "name": "music-player",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop music player built with Electron, React, TypeScript, and SQLite.",
  "author": "PulseLocal",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:desktop\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:desktop": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron/electron --ext js --exec electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "lint": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "db:init": "tsx scripts/init-db.ts",
    "start": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "^12.4.2",
    "music-metadata": "^10.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
