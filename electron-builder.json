{
  "appId": "com.local.musicplayer",
  "productName": "PulseLocal",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist-electron/electron/main.js"
  },
  "win": {
    "signAndEditExecutable": false,
    "target": [
      "nsis"
    ]
  }
}
